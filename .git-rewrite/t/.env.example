# PAD+ AI v4.0 — Environment Variables Example
# Скопируйте в .env и заполните значениями

# === ОСНОВНЫЕ НАСТРОЙКИ ===
APP_NAME=PAD+ AI
APP_VERSION=4.0.0
DEBUG=true
LANGUAGE=ru

# === БАЗА ДАННЫХ (Supabase/PostgreSQL) ===
# Вариант 1: Supabase Cloud
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_-1mxWi8Z5oYgjekKxUuiWw_SMxaQLs_

# Вариант 2: Локальный PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/padplus_db

# === ШИФРОВАНИЕ (КРИТИЧНО ВАЖНО!) ===
# Сгенерируйте ключ:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=V10eWM3fOzyYr0OtHGIJ_FKWkxEhBNEMDKnRD2T-LJI=

# Соль для шифрования (обязательно для Render!)
# Сгенерируйте один раз и сохраните:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# ⚠️ При потере соли все зашифрованные ключи станут нечитаемыми!
ENCRYPTION_SALT=<сгенерируйте и сохраните>

# === CSRF ЗАЩИТА ===
# Секретный ключ для CSRF токенов (обязательно для production!)
# Сгенерируйте:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
CSRF_SECRET_KEY=<сгенерируйте и сохраните>

# === FRONTEND ===
FRONTEND_URL=http://localhost:5174

# === BACKEND ===
BACKEND_PORT=8080

# === REDIS (опционально, для кэша) ===
REDIS_URL=redis://localhost:6379/0

# === LOGGING ===
LOG_LEVEL=info

# === GIGACHAT (Sber AI) ===
# Authorization key из консоли разработчика GigaChat
# Получить: https://developers.sber.ru/gigachat
GIGACHAT_AUTH_KEY=<ваш GigaChat authorization key>

# PAD+ AI v4.0 — Конфигурация (ПРИМЕР)
# 
# ВАЖНО: Скопируйте этот файл в .env и заполните действительные значения
# .env файл НЕ должен коммититься в git (уже в .gitignore)
# 
# Для production на Render установите эти переменные через:
# https://dashboard.render.com/ → Environment → Variables

# === ОСНОВНЫЕ НАСТРОЙКИ ===
APP_NAME=PAD+ AI
APP_VERSION=4.0.0
DEBUG=false
LANGUAGE=ru

# === БАЗА ДАННЫХ (Supabase PostgreSQL) ===
# Получите подключение из https://supabase.co dashboard
# Формат: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@aws-region.pooler.supabase.com:6543/postgres

# === ШИФРОВАНИЕ (КРИТИЧНО!) ===
# Генерируется: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# НИКОГДА не используйте те же ключи для разных сред!
ENCRYPTION_KEY=generated_key_here_32_bytes_base64_encoded
ENCRYPTION_SALT=generated_salt_here_32_bytes_base64_encoded

# === SUPABASE (для API клиента) ===
# Publishable key только (НЕ service role key для клиента!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_xxxxx
# Service role key — для операций, требующих обхода RLS (загрузка документов и т.д.)
# ВАЖНО: Никогда не используйте этот ключ на клиентской стороне!
SUPABASE_SERVICE_KEY=sb_secret_your_service_role_key_here

# === БЕЗОПАСНОСТЬ ===
# Генерируется: python -c "import secrets; print(secrets.token_urlsafe(32))"
CSRF_SECRET_KEY=generated_csrf_secret_here
ADMIN_MASTER_KEY=change-in-production

# === ЭМОЦИИ ===
EMOTION_DECAY_RATE=0.01
EMOTION_MIN=-1.0
EMOTION_MAX=1.0

# === ПАМЯТЬ ===
MEMORY_HUSK_TTL=3600
MEMORY_SOIL_TTL=2592000
MEMORY_ROOTS_TTL=-1

# === АВТОНОМНОСТЬ ===
PLANNER_INTERVAL=1800

# === РЕФЛЕКСИЯ ===
# Интервал циклов эволюции личности (диалогов)
REFLECTION_INTERVAL=10
# Порог низкой уверенности для X-Ray рефлексии
REFLECTION_LOW_CONFIDENCE=0.5
# Порог когнитивной нагрузки
REFLECTION_HIGH_LOAD=0.8
# Порог медленного выполнения (мс)
REFLECTION_SLOW_MS=5000

# === СНОВИДЕНИЯ ===
# Интервал запуска снов (диалогов)
DREAM_INTERVAL=20
# Минимальное время простоя для сна (минут)
DREAM_MIN_IDLE_MINUTES=30
# Длительность сна (сек)
DREAM_DURATION=60
# Эпизодов за сон
DREAM_EPISODES_PER_DREAM=50
# Порог связей в knowledge graph
DREAM_CONNECTION_THRESHOLD=0.6
# Затухание эмоций во сне
DREAM_EMOTION_DECAY=0.5

# === КОНСОЛИДАЦИЯ ПАМЯТИ ===
# Интервал консолидации (диалогов)
CONSOLIDATION_INTERVAL=10

# === META-CONTROLLER ===
# Диалогов до рефлексии
META_REFLECTION_DIALOGS=10
# Порог низкой успешности стратегий
META_LOW_SUCCESS=0.4
# Порог значимости для принудительной рефлексии
META_HIGH_SIGNIFICANCE=0.8

# === FRONTEND ===
# На Render: https://your-frontend.onrender.com
# На локальной машине: http://localhost:5174
FRONTEND_URL=http://localhost:5174

# === BACKEND ===
BACKEND_PORT=8080

# === REDIS (для кэша) ===
# На Render используйте Redis сервис или Upstash
# Формат: rediss://default:password@host:port
REDIS_URL=rediss://default:password@host:port

# === RATE LIMITING ===
RATE_LIMIT_PER_MINUTE=60

# === LLM CONFIGURATION ===
LLM_TIMEOUT=30
LLM_VERIFY_TLS=true
USE_FREE_MODELS=false  # Set to true to use only free OpenRouter models
GIGACHAT_VERIFY_TLS=false  # Отключить SSL для GigaChat (самоподписанный сертификат Сбера)
GIGACHAT_PROFANITY_CHECK=false  # Включить проверку ненормативной лексики в GigaChat

# === RENDER DEPLOYMENT ===
# Автоматически установится на Render:
# RENDER=true
# PORT=<автоматический>
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

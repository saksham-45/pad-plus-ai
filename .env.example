# PAD+ AI v3.5 — Пример конфигурации
# Скопируйте в .env и заполните значениями

# === ОСНОВНЫЕ НАСТРОЙКИ ===
APP_NAME=PAD+ AI
APP_VERSION=3.5.0
DEBUG=true
LANGUAGE=ru

# === LLM ПРОВАЙДЕРЫ ===
# OpenRouter (рекомендуется для production)
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=true
OPENROUTER_MODEL=google/gemma-7b-it

# GigaChat (альтернатива)
GIGACHAT_API_KEY=
GIGACHAT_ENABLED=false

# Google Gemini
GOOGLE_API_KEY=
GEMINI_ENABLED=false

# === БАЗА ДАННЫХ ===
DATABASE_URL=sqlite:///./data/memory.db

# === БЕЗОПАСНОСТЬ ===
ADMIN_MASTER_KEY=your-secret-key-here
X_ADMIN_TOKEN=your-admin-token-here

# === ЭМОЦИИ ===
EMOTION_DECAY_RATE=0.01
EMOTION_MIN=-1.0
EMOTION_MAX=1.0

# === ПАМЯТЬ ===
MEMORY_HUSK_TTL=3600      # 1 час (в секундах)
MEMORY_SOIL_TTL=2592000   # 30 дней (в секундах)
MEMORY_ROOTS_TTL=-1       # Бессрочно

# === АВТОНОМИЯ ===
PLANNER_INTERVAL=1800     # 30 минут (в секундах)
REFLECTION_INTERVAL=86400 # 1 сутки (в секундах)

# === PRODUCTION (Render) ===
# FRONTEND_URL=https://your-app.onrender.com
# BACKEND_URL=https://your-backend.onrender.com